{
  "compileOnSave": false,
    "compilerOptions": {
      "skipLibCheck": true,
  "baseUrl": "./",
      "outDir": "./dist/out-tsc",
      "sourceMap": true,
      "esModuleInterop": true,
      "declaration": false,
      "moduleResolution": "bundler",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "resolveJsonModule": true,
      "target": "esnext",
      "typeRoots": [
        "node_modules/@types"
      ],
      "lib": [
        "es2021",
        "dom"
      ]
    }
}
